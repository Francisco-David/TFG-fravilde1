        <zeebe:taskDefinition type="mostrarAlarma" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0s1po4f</bpmn:incoming>
      <bpmn:outgoing>Flow_0q5phtk</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_07j33ws" name="Mostrar advertencia">
