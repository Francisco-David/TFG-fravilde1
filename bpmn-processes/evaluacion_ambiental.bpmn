        <zeebe:taskDefinition type="leerLecturas" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1jvo5sh</bpmn:incoming>
      <bpmn:outgoing>Flow_1tfdt8g</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:startEvent id="Timer" name="5 minutos">
