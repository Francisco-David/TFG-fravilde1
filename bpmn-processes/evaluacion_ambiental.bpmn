  <bpmn:process id="eval-ambiental" name="" isExecutable="true">
    <bpmn:extensionElements />
    <bpmn:sequenceFlow id="Flow_0q5phtk" sourceRef="Activity_10jcal5" targetRef="ComprobarEstado" />
    <bpmn:sequenceFlow id="Flow_19f90an" sourceRef="Activity_07j33ws" targetRef="ComprobarEstado" />
    <bpmn:sequenceFlow id="Flow_0s1po4f" name="ALARMA" sourceRef="PuntuacionEvaluacion" targetRef="Activity_10jcal5">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=puntuacion&lt;30</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1x69fan" name="ADVERTENCIA" sourceRef="PuntuacionEvaluacion" targetRef="Activity_07j33ws">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=30&lt;=puntuacion and puntuacion&lt;=70</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1m4y154" name="OK" sourceRef="PuntuacionEvaluacion" targetRef="ComprobarEstado">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=puntuacion&gt;70</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1jfb7xu" sourceRef="EvaluacionAmbiental" targetRef="PuntuacionEvaluacion" />
    <bpmn:sequenceFlow id="Flow_1tfdt8g" sourceRef="UltimaLectura" targetRef="EvaluacionAmbiental" />
