  <bpmn:process id="eval-ambiental" isExecutable="true">
    <bpmn:extensionElements />
    <bpmn:sequenceFlow id="Flow_0q5phtk" sourceRef="Activity_10jcal5" targetRef="Event_0ldep8y" />
    <bpmn:sequenceFlow id="Flow_19f90an" sourceRef="Activity_07j33ws" targetRef="Event_0ldep8y" />
    <bpmn:sequenceFlow id="Flow_0s1po4f" name="ALARMA" sourceRef="Gateway_1gt2oil" targetRef="Activity_10jcal5">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=resultado&lt;30</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1x69fan" name="ADVERTENCIA" sourceRef="Gateway_1gt2oil" targetRef="Activity_07j33ws">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=30&lt;=resultado and resultado&lt;=70</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1m4y154" name="OK" sourceRef="Gateway_1gt2oil" targetRef="Event_10u3id1">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=resultado&gt;70</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1jfb7xu" sourceRef="EvaluacionAmbiental" targetRef="Gateway_1gt2oil" />
    <bpmn:sequenceFlow id="noValida" name="No" sourceRef="SonValidas" targetRef="AlarmaSensor">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=esValida</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="esValida" name="Si" sourceRef="SonValidas" targetRef="EvaluacionAmbiental">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=esValida</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1tfdt8g" sourceRef="UltimaLectura" targetRef="SonValidas" />
    <bpmn:sequenceFlow id="Flow_1jvo5sh" sourceRef="Timer" targetRef="UltimaLectura" />
    <bpmn:serviceTask id="Activity_10jcal5" name="Mostrar alarma ambiental">
