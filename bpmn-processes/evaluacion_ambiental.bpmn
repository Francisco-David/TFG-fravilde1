<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1qqhaln" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.37.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.7.0">
  <bpmn:process id="eval-ambiental" name="" isExecutable="true">
    <bpmn:extensionElements />
    <bpmn:sequenceFlow id="Flow_0q5phtk" sourceRef="Activity_10jcal5" targetRef="ComprobarEstado" />
    <bpmn:sequenceFlow id="Flow_19f90an" sourceRef="Activity_07j33ws" targetRef="ComprobarEstado" />
    <bpmn:sequenceFlow id="Flow_0s1po4f" name="ALARMA" sourceRef="PuntuacionEvaluacion" targetRef="Activity_10jcal5">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=puntuacion&lt;30</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1x69fan" name="ADVERTENCIA" sourceRef="PuntuacionEvaluacion" targetRef="Activity_07j33ws">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=30&lt;=puntuacion and puntuacion&lt;=70</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1m4y154" name="OK" sourceRef="PuntuacionEvaluacion" targetRef="ComprobarEstado">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=puntuacion&gt;70</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1jfb7xu" sourceRef="EvaluacionAmbiental" targetRef="PuntuacionEvaluacion" />
    <bpmn:sequenceFlow id="noValida" name="No" sourceRef="SonValidas" targetRef="AlarmaSensor">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=sonValidas</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="esValida" name="Si" sourceRef="SonValidas" targetRef="EvaluacionAmbiental">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=sonValidas</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1tfdt8g" sourceRef="UltimaLectura" targetRef="SonValidas" />
    <bpmn:serviceTask id="Activity_10jcal5" name="Mostrar alarma ambiental">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="mostrarAlarma" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0s1po4f</bpmn:incoming>
      <bpmn:outgoing>Flow_0q5phtk</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_07j33ws" name="Mostrar advertencia">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="mostrarAdvertencia" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1x69fan</bpmn:incoming>
      <bpmn:outgoing>Flow_19f90an</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EventoFinalizarEvaluaciones" name="Finalizar evaluaciones sesión">
      <bpmn:incoming>Flow_0tlg5p9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="PuntuacionEvaluacion" name="Puntuación en evalución">
      <bpmn:incoming>Flow_1jfb7xu</bpmn:incoming>
      <bpmn:outgoing>Flow_1m4y154</bpmn:outgoing>
      <bpmn:outgoing>Flow_1x69fan</bpmn:outgoing>
      <bpmn:outgoing>Flow_0s1po4f</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="AlarmaSensor" name="Alarma sensor">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="alarmaSensor" />
      </bpmn:extensionElements>
      <bpmn:incoming>noValida</bpmn:incoming>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="EvaluacionAmbiental" name="Evaluación ambiental">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="calculoEvaluacion" />
      </bpmn:extensionElements>
      <bpmn:incoming>esValida</bpmn:incoming>
      <bpmn:outgoing>Flow_1jfb7xu</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="SonValidas" name="Son válidas">
      <bpmn:incoming>Flow_1tfdt8g</bpmn:incoming>
      <bpmn:outgoing>esValida</bpmn:outgoing>
      <bpmn:outgoing>noValida</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="UltimaLectura" name="Leer última lectura">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="leerLecturas" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1jvo5sh</bpmn:incoming>
      <bpmn:incoming>Flow_1y03not</bpmn:incoming>
      <bpmn:outgoing>Flow_1tfdt8g</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="SigueCurso" name="Sigue en curso">
      <bpmn:incoming>Flow_1yztjd2</bpmn:incoming>
      <bpmn:outgoing>Flow_0k5epoi</bpmn:outgoing>
      <bpmn:outgoing>Flow_0tlg5p9</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ComprobarEstado" name="Comprobar estado de sesión">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="comprobarEstado" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1m4y154</bpmn:incoming>
      <bpmn:incoming>Flow_0q5phtk</bpmn:incoming>
      <bpmn:incoming>Flow_19f90an</bpmn:incoming>
      <bpmn:outgoing>Flow_1yztjd2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1yztjd2" sourceRef="ComprobarEstado" targetRef="SigueCurso" />
    <bpmn:sequenceFlow id="Flow_0k5epoi" name="En curso" sourceRef="SigueCurso" targetRef="TimerBucle">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=estadoSesion="en_curso"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0tlg5p9" name="Finalizada" sourceRef="SigueCurso" targetRef="EventoFinalizarEvaluaciones">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=estadoSesion="finalizada"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:startEvent id="EventoComenzarEvaluacion" name="Comenzar evaluaciones sesión">
      <bpmn:outgoing>Flow_0127g2c</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_0127g2c" sourceRef="EventoComenzarEvaluacion" targetRef="TimerSetup" />
    <bpmn:intermediateCatchEvent id="TimerBucle" name="5 minutos">
      <bpmn:incoming>Flow_0k5epoi</bpmn:incoming>
      <bpmn:outgoing>Flow_1jvo5sh</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_0brl2ni">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT30S</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_1jvo5sh" sourceRef="TimerBucle" targetRef="UltimaLectura" />
    <bpmn:intermediateCatchEvent id="TimerSetup" name="Setup timer">
      <bpmn:incoming>Flow_0127g2c</bpmn:incoming>
      <bpmn:outgoing>Flow_1y03not</bpmn:outgoing>
