      <bpmn:outgoing>Flow_1xf6lur</bpmn:outgoing>
      <bpmn:outgoing>TemperaturaBaja</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="TemperaturaAlta" name="tem&#62;25º" sourceRef="ValorTemperatura" targetRef="ActivarAlarmaTem">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=temperatura&gt;25</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_1vy1qnk">
      <bpmn:incoming>Flow_1xf6lur</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1xf6lur" sourceRef="ValorTemperatura" targetRef="Event_1vy1qnk">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=19&lt;=temperatura and temperatura &lt;=25</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="Activity_04ymudy" name="Activar alarma por baja temperatura">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="activar-alarma-tem" />
      </bpmn:extensionElements>
      <bpmn:incoming>TemperaturaBaja</bpmn:incoming>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="TemperaturaBaja" name="tem&#60;19º" sourceRef="ValorTemperatura" targetRef="Activity_04ymudy">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=temperatura&lt;19</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
