  <bpmn:process id="alarma-temperatura" isExecutable="true">
    <bpmn:startEvent id="LecturaTemperatura" name="Lectura Temperatura">
      <bpmn:outgoing>Flow_01q04uh</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="ActivarAlarmaTem" name="Activar alarma por alta temperatura">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="activar-alarma-tem" />
      </bpmn:extensionElements>
      <bpmn:incoming>TemperaturaAlta</bpmn:incoming>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_01q04uh" sourceRef="LecturaTemperatura" targetRef="ValorTemperatura" />
    <bpmn:exclusiveGateway id="ValorTemperatura" name="">
      <bpmn:extensionElements />
      <bpmn:incoming>Flow_01q04uh</bpmn:incoming>
